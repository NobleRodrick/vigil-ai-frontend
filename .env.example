# VIGIL-AI Cameroun — Frontend Environment Variables
# Copy this file to .env and adjust if your backend runs elsewhere.

# Base URL of the FastAPI backend (no trailing slash, no /api/v1 suffix)
VITE_API_URL=http://localhost:8000

# WebSocket base URL — only set this if it differs from VITE_API_URL
# (defaults to VITE_API_URL with http→ws / https→wss substitution)
# VITE_WS_URL=ws://localhost:8000
